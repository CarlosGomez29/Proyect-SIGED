
{
  "entities": {
    "Escuela": {
      "title": "Escuela Vocacional",
      "description": "Centro educativo institucional.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string", "description": "Nombre oficial" },
        "provincia": { "type": "string" },
        "ubicacion": { "type": "string", "description": "Link de Google Maps" },
        "telefono": { "type": "string" },
        "extension": { "type": "string" },
        "estado": { "type": "string", "enum": ["activo", "inactivo"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nombre", "provincia", "estado"]
    },
    "Provincia": {
      "title": "Provincia",
      "description": "Catálogo de provincias dominicanas.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" }
      },
      "required": ["nombre"]
    },
    "AcademicPeriod": {
      "title": "Periodo Académico",
      "description": "Ciclo lectivo global gestionado por el SuperAdmin.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string", "description": "Ej. Año Escolar 2025-2026" },
        "fechaInicio": { "type": "string", "format": "date" },
        "fechaFin": { "type": "string", "format": "date" },
        "estado": { "type": "string", "enum": ["activo", "inactivo"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nombre", "fechaInicio", "fechaFin", "estado"]
    },
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Información extendida del usuario y su rol.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "apellido": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telefono": { "type": "string" },
        "rol": { "type": "string", "enum": ["superadmin", "admin", "admision"] },
        "escuelaId": { "type": "string", "description": "ID de la escuela asignada (null para superadmin)" },
        "estado": { "type": "string", "enum": ["activo", "inactivo"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nombre", "apellido", "email", "rol", "estado"]
    },
    "Sede": {
      "title": "Sede / Recinto",
      "description": "Recinto físico donde se imparten los programas académicos.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string", "description": "Nombre oficial del recinto" },
        "ubicacion": { "type": "string", "description": "Provincia o municipio" },
        "codigo": { "type": "string", "description": "Código interno de la sede" }
      },
      "required": ["nombre", "codigo"]
    },
    "Curso": {
      "title": "Curso Académico",
      "description": "Definición del programa técnico (Curricula).",
      "type": "object",
      "properties": {
        "nombre": { "type": "string", "description": "Nombre del programa técnico" },
        "codigo": { "type": "string", "description": "Código del plan de estudios" },
        "descripcion": { "type": "string" },
        "duracionHoras": { "type": "integer" }
      },
      "required": ["nombre", "codigo"]
    },
    "Docente": {
      "title": "Docente",
      "description": "Personal encargado de impartir docencia con perfil extendido.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "apellido": { "type": "string" },
        "cedula": { "type": "string", "description": "Mapeado de documento_identidad" },
        "correo": { "type": "string", "format": "email" },
        "telefono": { "type": "string" },
        "direccion": { "type": "string" },
        "fecha_nacimiento": { "type": "string", "format": "date" },
        "foto_perfil": { "type": "string", "description": "URL de la imagen" },
        "fecha_ingreso": { "type": "string", "format": "date" },
        "escuelaId": { "type": "string", "description": "Referencia a escuelas" },
        "rango_militar": { "type": "string" },
        "profesion": { "type": "string", "description": "Formación profesional: Carrera que estudió el docente." },
        "institucion": { "type": "string" },
        "sexo": { "type": "string", "enum": ["Masculino", "Femenino"] },
        "estado_civil": { "type": "string", "enum": ["Soltero", "Casado", "Divorciado", "Viudo"] },
        "cantidad_hijos": { "type": "integer" },
        "cv_url": { "type": "string", "description": "Enlace al CV (PDF) o Portafolio digital" },
        "clave_access": { "type": "string" },
        "estado": { "type": "string", "enum": ["Activo", "Inactivo"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nombre", "apellido", "cedula", "correo", "estado"]
    },
    "Estudiante": {
      "title": "Estudiante / Alumno",
      "description": "Persona inscrita en los programas.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "apellido": { "type": "string" },
        "cedula": { "type": "string" },
        "matricula": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["nombre", "matricula"]
    },
    "Seccion": {
      "title": "Sección Académica",
      "description": "Instancia de un curso en un periodo, sede y docente específico.",
      "type": "object",
      "properties": {
        "codigoSeccion": { "type": "string", "description": "Código secuencial global SEC-XXXX" },
        "cursoId": { "type": "string", "description": "Referencia al ID del Curso" },
        "periodoId": { "type": "string", "description": "Referencia al ID del Periodo" },
        "sedeId": { "type": "string", "description": "Referencia al ID de la Sede" },
        "docenteId": { "type": "string", "description": "Referencia al ID del Docente" },
        "horario": { "type": "string" },
        "capacidad": { "type": "integer" },
        "inscritos": { "type": "integer", "default": 0 },
        "estado": { "type": "string", "enum": ["Abierta", "Cerrada", "Finalizada"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["codigoSeccion", "cursoId", "periodoId", "sedeId", "estado"]
    },
    "Inscripcion": {
      "title": "Inscripción y Calificación",
      "description": "Registro de un estudiante en una sección con su nota.",
      "type": "object",
      "properties": {
        "seccionId": { "type": "string" },
        "estudianteId": { "type": "string" },
        "calificacionFinal": { "type": "number", "minimum": 0, "maximum": 100 },
        "estado": { "type": "string", "enum": ["Inscrito", "Retirado", "Aprobado", "Reprobado"] },
        "fechaInscripcion": { "type": "string", "format": "date-time" }
      },
      "required": ["seccionId", "estudianteId", "estado"]
    },
    "RangoMilitar": {
      "title": "Rango Militar",
      "description": "Catálogo institucional de rangos militares.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string", "description": "Nombre del rango" },
        "orden": { "type": "integer", "description": "Orden jerárquico" }
      },
      "required": ["nombre", "orden"]
    },
    "Institucion": {
      "title": "Institución",
      "description": "Catálogo oficial de instituciones castrenses y policiales.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string", "description": "Nombre o siglas de la institución" },
        "orden": { "type": "integer", "description": "Orden de visualización" }
      },
      "required": ["nombre", "orden"]
    },
    "Programa": {
      "title": "Programa Académico",
      "description": "Clasificación de acciones formativas.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string", "description": "Nombre oficial del programa" },
        "estado": { "type": "string", "enum": ["activo", "inactivo"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nombre", "estado"]
    },
    "MetadataCounters": {
      "title": "Contadores de Systema",
      "description": "Estado de los contadores secuenciales para IDs institucionales.",
      "type": "object",
      "properties": {
        "inst_secciones_count": { "type": "integer", "description": "Último número usado para secciones (SEC-XXXX)" },
        "inst_docentes_count": { "type": "integer", "description": "Último número usado para docentes (REG-XXXX)" }
      }
    },
    "Auditoria": {
      "title": "Registro de Auditoría",
      "description": "Trazabilidad de acciones del sistema.",
      "type": "object",
      "properties": {
        "usuario": { "type": "string" },
        "accion": { "type": "string" },
        "modulo": { "type": "string" },
        "escuela": { "type": "string" },
        "modo": { "type": "string", "enum": ["superadmin", "standard"] },
        "fecha": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Perfiles de usuario y roles." },
    "/escuelas/{escuelaId}": { "schema": "Escuela", "description": "Maestro de recintos." },
    "/provincias/{provinciaId}": { "schema": "Provincia", "description": "Catálogo de provincias." },
    "/academic_periods/{periodId}": { "schema": "AcademicPeriod", "description": "Ciclos lectivos globales." },
    "/sedes/{sedeId}": { "schema": "Sede", "description": "Maestro de recintos (legacy)." },
    "/cursos/{cursoId}": { "schema": "Curso", "description": "Maestro de programas." },
    "/docentes/{docenteId}": { "schema": "Docente", "description": "Docentes." },
    "/estudiantes/{estudianteId}": { "schema": "Estudiante", "description": "Alumnos." },
    "/secciones/{seccionId}": { "schema": "Seccion", "description": "Secciones operativas." },
    "/inscripciones/{inscripcionId}": { "schema": "Inscripcion", "description": "Control de alumnos y notas." },
    "/rangos_militares/{rangoId}": { "schema": "RangoMilitar", "description": "Catálogo de rangos militares." },
    "/instituciones/{institucionId}": { "schema": "Institucion", "description": "Catálogo de instituciones oficiales." },
    "/programas/{programaId}": { "schema": "Programa", "description": "Catálogo de programas académicos." },
    "/auditoria/{auditId}": { "schema": "Auditoria", "description": "Registros de trazabilidad." },
    "/metadata/counters": { 
      "schema": { "$ref": "#/backend/entities/MetadataCounters" }, 
      "description": "Contadores atómicos." 
    }
  }
}
