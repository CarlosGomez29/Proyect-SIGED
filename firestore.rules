rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get user's role from the 'users' collection
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // USERS collection
    match /users/{userId} {
      allow create: if request.auth != null;
      allow read: if request.auth.uid == userId
                   || getUserRole(request.auth.uid) in ['administrador', 'super-admin'];
      allow update: if request.auth.uid == userId
                     || getUserRole(request.auth.uid) in ['administrador', 'super-admin'];
      allow delete: if getUserRole(request.auth.uid) in ['administrador', 'super-admin'];
    }

    // SECCIONES collection
    match /secciones/{seccionId} {
        // Admins and Super-Admins have full access
        allow read, write: if getUserRole(request.auth.uid) in ['administrador', 'super-admin'];
        
        // Instructors and Admissions can read sections
        allow read: if getUserRole(request.auth.uid) in ['instructor', 'admision'];
    }

    // ALUMNOS collection
    match /alumnos/{alumnoId} {
        allow read, write: if getUserRole(request.auth.uid) in ['administrador', 'super-admin', 'admision'];
        allow read: if request.auth.uid == alumnoId;
        allow read: if getUserRole(request.auth.uid) == 'instructor';
    }

    // CURSOS collection
    match /cursos/{cursoId} {
        allow read, write: if getUserRole(request.auth.uid) in ['administrador', 'super-admin'];
        allow read: if getUserRole(request.auth.uid) in ['instructor', 'admision'];
        allow read: if getUserRole(request.auth.uid) == 'alumno';
    }

    // INSCRIPCIONES collection
    match /inscripciones/{inscripcionId} {
        allow read, write: if getUserRole(request.auth.uid) in ['administrador', 'super-admin', 'admision'];
        allow read: if request.auth.uid == resource.data.alumnoId;
    }

    // PAGOS collection
    match /pagos/{pagoId} {
        allow read, write: if getUserRole(request.auth.uid) in ['administrador', 'super-admin', 'admision'];
        allow read: if request.auth.uid == resource.data.alumnoId;
    }

    // CALIFICACIONES collection
    match /calificaciones/{calificacionId} {
        allow read, write: if getUserRole(request.auth.uid) in ['administrador', 'super-admin'];
        allow write: if getUserRole(request.auth.uid) == 'instructor';
        allow read: if getUserRole(request.auth.uid) in ['instructor', 'admision'] 
                    || request.auth.uid == resource.data.alumnoId;
    }
  }
}