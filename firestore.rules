rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas permisivas para la fase de prototipado y desarrollo
    // Permiten el acceso a las colecciones principales sin requerir Auth de Firebase 
    // mientras se utiliza el simulador de roles del sistema.
    
    match /secciones/{seccionId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if true;
    }
    
    // Regla por defecto para el resto de la base de datos
    match /{document=**} {
      allow read, write: if true;
    }
  }
}