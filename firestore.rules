
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /escuelas/{escuelaId} {
      allow read, write: if true;
    }
    match /provincias/{provinciaId} {
      allow read, write: if true;
    }
    match /academic_periods/{periodId} {
      allow read, write: if true;
    }
    match /modulos/{moduloId} {
      allow read, write: if true;
    }
    match /acciones_formativas/{accionId} {
      allow read, write: if true;
      match /modulos/{subModuloId} {
        allow read, write: if true;
      }
    }
    match /sedes/{sedeId} {
      allow read, write: if true;
    }
    match /cursos/{cursoId} {
      allow read, write: if true;
    }
    match /periodos/{periodoId} {
      allow read, write: if true;
    }
    match /docentes/{docenteId} {
      allow read, write: if true;
    }
    match /estudiantes/{estudianteId} {
      allow read, write: if true;
    }
    match /secciones/{seccionId} {
      allow read, write: if true;
    }
    match /inscripciones/{inscripcionId} {
      allow read, write: if true;
    }
    match /rangos_militares/{rangoId} {
      allow read, write: if true;
    }
    match /instituciones/{institucionId} {
      allow read, write: if true;
    }
    match /programas/{programaId} {
      allow read, write: if true;
    }
    match /metadata/counters {
      allow read, write: if true;
    }
    match /auditoria/{auditId} {
      allow read, write: if true;
    }
    match /users/{userId} {
      allow read, write: if true;
    }
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
